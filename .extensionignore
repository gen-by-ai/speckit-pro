# .extensionignore — files excluded from the installed copy
# Development and CI files
.git/
.github/
.gitignore
.vscode/
.DS_Store
.agents/
.specify/

# Test files (the smoke suite scripts/tests/hardening-smoke.sh SHIPS — it is a
# consumer-runnable post-install self-check referenced by .knowledge/INDEX.md)
*.test.sh
*.test.ps1

# Workspace state — gitignored in the source repo; excluding it here keeps
# dev installs (--dev .) identical to the consumer GitHub-archive package, so
# a doc reference into these paths fails loudly during dogfooding instead of
# silently working only on the dev machine.
specs/
CLAUDE.md
.knowledge/

# Documentation source (README.md is kept)
CONTRIBUTING.md
docs/
IMPROVEMENTS.md

# Build artifacts
__pycache__/
*.pyc
dist/
*.egg-info/

# Config files (user provides their own)
# Note: pro-config.template.yml IS included (it's the template)
.env
*.local.yml
